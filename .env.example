# ============================================================
# Pixel Wars — Конфигурация окружения
# Скопируйте в .env и заполните реальные значения
# ============================================================

# Сервер
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://pixelwars.yourdomain.com

# JWT
JWT_SECRET=здесь_случайная_строка_минимум_64_символа

# PostgreSQL
DATABASE_URL=postgresql://pixelwars:your_password@localhost:5432/pixelwars

# Redis
REDIS_URL=redis://localhost:6379

# Telegram Bot (для Login Widget)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_USERNAME=YourPixelWarsBot

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxxxxxxxxxx
